---
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (path: string) => (path === "/" ? `${baseUrl}/` || "/" : `${baseUrl}${path}`);
---

<footer class="site-footer">
  <div>
    <h3>Charles-Antoine Menanteau</h3>
    <p>Psychologue clinicien • Psychothérapeute<br />Hypnothérapeute</p>
    <p>Une pratique clinique attentive à l’expérience vécue, aux crises de sens et aux transformations intérieures.</p>
  </div>
  <div>
    <h4>Informations pratiques</h4>
    <p>Cabinets à Nantes et Clisson</p>
    <p>Sur rendez-vous</p>
  </div>
  <div>
    <h4>Contact</h4>
    <p>06 00 00 00 00</p>
    <p>contact@charlesantoine-menanteau.fr</p>
    <p><a href={withBase("/contact")}>Formulaire de contact</a></p>
    <p><a href={withBase("/liens-utiles")}>Liens utiles</a></p>
  </div>
  <div class="footer-mark" aria-hidden="true"></div>
</footer>
