---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (path) => (path === "/" ? `${baseUrl}/` || "/" : `${baseUrl}${path}`);
---

<BaseLayout
  title="Contact | Charles-Antoine Menanteau"
  description="Contact, prise de rendez-vous, cabinets à Nantes et Clisson."
  currentPath="/contact"
>
  <section class="page-hero-grid">
    <div class="page-hero-copy">
      <p class="page-eyebrow">Contact</p>
      <h1>Prendre contact pour un premier échange ou une demande de rendez-vous.</h1>
      <span class="heading-rule"></span>
      <p class="page-intro">
        Cette page rassemble les informations pratiques pour les consultations en cabinet à Nantes
        et à Clisson, ainsi qu’un premier point de contact.
      </p>
    </div>
    <div class="page-hero-visual">
      <div class="page-hero-art page-hero-art-interior"></div>
    </div>
  </section>

  <section class="dynamic-grid dynamic-grid-2 page-section">
    <details class="content-card dynamic-panel">
      <summary class="dynamic-summary">
        <span>
          <span class="dynamic-kicker">Rendez-vous</span>
          <span class="dynamic-heading">Consultations</span>
        </span>
        <span class="dynamic-toggle" aria-hidden="true"></span>
      </summary>
      <p>En cabinet à Nantes et à Clisson, sur rendez-vous.</p>
    </details>
    <details class="content-card dynamic-panel">
      <summary class="dynamic-summary">
        <span>
          <span class="dynamic-kicker">Contact direct</span>
          <span class="dynamic-heading">Coordonnees</span>
        </span>
        <span class="dynamic-toggle" aria-hidden="true"></span>
      </summary>
      <p>Téléphone, email, adresses précises, horaires et accès seront à confirmer.</p>
    </details>
  </section>

  <section class="cabinet-gallery page-section">
    <div class="section-heading">
      <p class="page-eyebrow">Cadre de consultation</p>
      <h2>Les cabinets</h2>
      <span class="heading-rule"></span>
      <p class="section-intro">
        Deux lieux de consultation permettent d’accueillir les adolescents et les adultes, à Nantes
        et à Clisson.
      </p>
    </div>

    <div class="gallery-grid">
      <figure class="gallery-item">
        <img src={withBase("/assets/interior-page-art.png")} alt="Espace de consultation calme et lumineux" loading="lazy" />
        <figcaption>Nantes</figcaption>
      </figure>
      <figure class="gallery-item">
        <img src={withBase("/assets/cabinet-cta.png")} alt="Cadre de travail du cabinet" loading="lazy" />
        <figcaption>Clisson</figcaption>
      </figure>
    </div>
  </section>
</BaseLayout>
