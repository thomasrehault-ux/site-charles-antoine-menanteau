---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Charles-Antoine Menanteau"
  description="Contact, prise de rendez-vous, cabinet a Nantes et consultations en visio."
  currentPath="/contact"
>
  <section class="page-hero-grid">
    <div class="page-hero-copy">
      <p class="page-eyebrow">Contact</p>
      <h1>Prendre contact pour un premier echange ou une demande de rendez-vous.</h1>
      <span class="heading-rule"></span>
      <p class="page-intro">
        Cette page peut accueillir les informations pratiques, une presentation simple du cadre, ainsi
        qu'un futur formulaire de contact.
      </p>
    </div>
    <div class="page-hero-visual">
      <div class="page-hero-art page-hero-art-interior"></div>
    </div>
  </section>

  <section class="content-grid page-section">
    <article class="content-card">
      <h2>Consultations</h2>
      <p>En cabinet a Nantes et en visio, sur rendez-vous.</p>
    </article>
    <article class="content-card">
      <h2>Coordonnees</h2>
      <p>Telephone, email, adresse precise, horaires et acces seront a confirmer.</p>
    </article>
  </section>
</BaseLayout>
