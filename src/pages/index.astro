---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (path) => (path === "/" ? `${baseUrl}/` || "/" : `${baseUrl}${path}`);

const motifs = [
  {
    title: "Anxiété et stress",
    text: "Crises d’angoisse, tension intérieure, sentiment de débordement, inquiétude persistante, insomnie."
  },
  {
    title: "Burn-out et dépression",
    text: "Épuisement psychique, perte d’élan, retrait, difficulté à retrouver des repères et une énergie vitale, ruminations."
  },
  {
    title: "Addictions",
    text: "Dépendances, répétitions, conduites d’échappement et rapport difficile à la limite ou au manque, obsessions."
  },
  {
    title: "Troubles des conduites alimentaires (TCA)",
    text: "Rapport conflictuel au corps, à l’alimentation, au contrôle ou à la régulation émotionnelle."
  },
  {
    title: "Trauma",
    text: "Événements difficiles, traces persistantes, état d’alerte, sidération, envahissement émotionnel, hypervigilance, cauchemars à répétition, dissociation."
  },
  {
    title: "Deuil et perte de sens",
    text: "Séparations, ruptures, décès, remaniements de vie, crises existentielles, étapes de vie, grossesse, post-partum, mariage, déménagement, réorientation professionnelle, retraite."
  }
];
---

<BaseLayout
  title="Charles-Antoine Menanteau | Psychologue clinicien"
  description="Charles-Antoine Menanteau, psychologue clinicien, psychothérapeute et hypnothérapeute à Nantes et Clisson."
  currentPath="/"
>
  <section class="hero">
    <div class="hero-copy">
      <p class="page-eyebrow">Psychologue clinicien · Nantes et Clisson</p>
      <h1>
        Accompagner<br />
        les périodes de crise et de<br />
        transformation<br />
        intérieure
      </h1>
      <span class="heading-rule"></span>
      <p class="hero-text">
        Psychologue clinicien, psychothérapeute et hypnothérapeute, j’accompagne les adolescents
        et les adultes confrontés à des moments de souffrance psychique, d’épuisement, de perte de
        repères ou de questionnement existentiel.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={withBase("/contact")}>Prendre rendez-vous</a>
        <a class="button button-secondary" href={withBase("/approche")}>Découvrir mon approche</a>
      </div>
      <p class="hero-note">
        Consultations en cabinet à Nantes et à Clisson
      </p>
    </div>

    <div class="hero-visual">
      <div class="hero-visual-art">
        <div class="visual-caption">
          <span>Cadre de travail</span>
          <p>Un espace calme pour remettre du mouvement dans ce qui semblait figé.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-hub">
    <div class="section-heading">
      <p class="page-eyebrow">Pour aller plus loin</p>
      <h2>Explorer le site</h2>
      <span class="heading-rule"></span>
      <p class="section-intro">
        Cette page d’accueil présente les grands repères de la pratique. Chaque rubrique se déploie
        ensuite pour préciser l’approche clinique, les motifs de consultation, le cadre des séances,
        le parcours et les ressources utiles.
      </p>
    </div>

    <div class="page-hub-grid">
      <article class="page-teaser page-teaser-highlight">
        <p class="page-teaser-kicker">Page clé</p>
        <h3>Mon approche</h3>
        <p>
          Comprendre les fondements de la pratique, la place de l’expérience vécue, du sens, de
          l’imaginaire et du cadre thérapeutique.
        </p>
        <a href={withBase("/approche")}>Lire la page</a>
      </article>
      <article class="page-teaser">
        <h3>Motifs de consultation</h3>
        <p>
          Retrouver les principales difficultés accompagnées et les situations de vie auxquelles ce
          travail thérapeutique peut répondre.
        </p>
        <a href={withBase("/motifs")}>Voir les motifs</a>
      </article>
      <article class="page-teaser">
        <h3>Déroulement des séances</h3>
        <p>
          Mieux comprendre le premier rendez-vous, le cadre de suivi et la place des différents
          outils.
        </p>
        <a href={withBase("/seances")}>Voir la page</a>
      </article>
      <article class="page-teaser">
        <h3>Parcours et formation</h3>
        <p>
          Découvrir le parcours, les formations et les repères cliniques qui soutiennent cette
          pratique.
        </p>
        <a href={withBase("/parcours")}>Découvrir le parcours</a>
      </article>
      <article class="page-teaser">
        <h3>Liens utiles</h3>
        <p>
          Accéder aux ressources et structures associées à la pratique: La Note Bleue, IFH,
          Ipnosia, CESHUM.
        </p>
        <a href={withBase("/liens-utiles")}>Voir les liens</a>
      </article>
    </div>
  </section>

  <section class="section motif-section">
    <div class="section-heading">
      <p class="page-eyebrow">Quelques repères</p>
      <h2>Motifs de consultation</h2>
      <span class="heading-rule"></span>
      <p class="section-intro">
        Les consultations peuvent concerner des difficultés psychiques, relationnelles ou
        existentielles. Chaque situation est accueillie dans sa singularité, sans être réduite à un
        symptôme ou à une catégorie.
      </p>
    </div>

    <div class="motif-list">
      {
        motifs.map((motif) => (
          <details class="motif-panel">
            <summary class="motif-summary">
              <span class="motif-heading">{motif.title}</span>
              <span class="motif-toggle" aria-hidden="true"></span>
            </summary>
            <div class="motif-detail">
              <p>{motif.text}</p>
              <a class="text-link" href={withBase("/motifs")}>Voir la page motifs</a>
            </div>
          </details>
        ))
      }
    </div>

    <div class="section-link-row">
      <a class="text-link" href={withBase("/motifs")}>Accéder à la page détaillée des motifs</a>
    </div>
  </section>

  <section class="approach-band">
    <div class="approach-copy">
      <div class="section-heading">
        <h2>Mon approche</h2>
        <span class="heading-rule"></span>
      </div>
      <p class="approach-lead">
        Une clinique de l’expérience vécue, du sens et du travail de l’imaginaire.
      </p>

      <ul class="approach-list">
        <li><span>Une présence attentive et bienveillante pour accueillir ce qui fait souffrance et lui redonner du sens.</span></li>
        <li><span>Un travail en profondeur qui mobilise à la fois la parole, l’émotion, le corps et l’imaginaire.</span></li>
        <li><span>Un accompagnement sur mesure, respectueux de votre histoire et de votre rythme de transformation.</span></li>
      </ul>

      <a class="band-link" href={withBase("/approche")}>Lire la page complète sur l’approche</a>
    </div>

    <div class="approach-visual">
      <div class="approach-visual-art"></div>
      <div class="approach-note">
        <p>Un espace pour relier ce qui se pense, ce qui se ressent et ce qui cherche à se transformer.</p>
      </div>
    </div>
  </section>

  <section class="section tools-section">
    <div class="section-heading">
      <p class="page-eyebrow">Cadre de travail</p>
      <h2>Outils thérapeutiques</h2>
      <span class="heading-rule"></span>
      <p class="section-intro">
        Selon les situations, le travail peut s’appuyer sur différentes médiations. Elles ne
        constituent pas une méthode appliquée automatiquement, mais des appuis choisis en fonction
        de la personne, de la demande et du moment traversé.
      </p>
    </div>

    <div class="tool-grid">
      <article class="tool-card">
        <span class="tool-kicker">Écoute clinique</span>
        <h3>Psychothérapie<br />par la parole</h3>
        <p>Un espace d’écoute pour élaborer ce qui se vit, clarifier la souffrance et retrouver des repères.</p>
      </article>
      <article class="tool-card">
        <span class="tool-kicker">États de conscience</span>
        <h3>Hypnose<br />thérapeutique</h3>
        <p>Une médiation possible pour favoriser le travail psychique lorsque les mots seuls ne suffisent pas.</p>
      </article>
      <article class="tool-card">
        <span class="tool-kicker">Imagination guidée</span>
        <h3>Rêve éveillé</h3>
        <p>Un travail de l’imaginaire permettant d’explorer autrement les conflits, les blocages et les ressources intérieures.</p>
      </article>
      <article class="tool-card">
        <span class="tool-kicker">Ancrage corporel</span>
        <h3>Respiration<br />et recentrage</h3>
        <p>Des appuis simples pour retrouver un ancrage, réguler l’intensité émotionnelle et soutenir la présence à soi.</p>
      </article>
    </div>

    <div class="section-link-row">
      <a class="text-link" href={withBase("/seances")}>Découvrir le déroulement des séances</a>
    </div>
  </section>

  <section class="section parcours-section">
    <div class="section-heading">
      <p class="page-eyebrow">Repères de pratique</p>
      <h2>Parcours</h2>
      <span class="heading-rule"></span>
      <p class="section-intro">
        Le travail clinique s’appuie sur une formation universitaire, des approfondissements
        thérapeutiques, une pratique de terrain, un travail de transmission et de supervision.
      </p>
    </div>

    <div class="parcours-timeline parcours-timeline-compact">
      <article class="timeline-step">
        <p class="timeline-meta">2009-2014</p>
        <h3>Formation universitaire</h3>
        <p>Psychologie clinique, recherche, pratique, pour l’obtention du diplôme de psychologue clinicien et psychothérapeute.</p>
      </article>
      <article class="timeline-step">
        <p class="timeline-meta">2012-2020</p>
        <h3>Approfondissements cliniques</h3>
        <p>Psychanalyse, anthropologie clinique, travail psycho-corporel, respiration et pratiques transpersonnelles.</p>
      </article>
      <article class="timeline-step">
        <p class="timeline-meta">Depuis 2020</p>
        <h3>Transmission, initiation, supervision</h3>
        <p>Hypnose, rêve éveillé phénoméno-existentiel et travail de l’imaginaire.</p>
      </article>
    </div>

    <div class="section-link-row">
      <a class="text-link" href={withBase("/parcours")}>Voir la page parcours et formation</a>
    </div>
  </section>

  <section class="cta-band">
    <div class="cta-copy">
      <div>
        <h2>Prendre soin de soi,<br />c’est déjà commencer à aller mieux.</h2>
        <p>Je vous accueille avec attention, discrétion et respect, à chaque étape de votre cheminement.</p>
      </div>
    </div>

    <div class="cta-contact">
      <div>
        <h3>Prendre rendez-vous</h3>
        <p>En cabinet à Nantes<br />ou à Clisson</p>
        <span class="heading-rule"></span>
        <a class="text-link text-link-dark" href={withBase("/contact")}>Accéder à la page contact</a>
      </div>
    </div>
  </section>

  <section class="profile-signoff" aria-label="Charles-Antoine Menanteau">
    <img
      class="profile-portrait"
      src={withBase("/assets/charles-antoine-menanteau.jpg")}
      alt="Portrait de Charles-Antoine Menanteau"
      loading="lazy"
    />
    <div>
      <p class="page-eyebrow">Charles-Antoine Menanteau</p>
      <p>Psychologue clinicien · Psychothérapeute · Hypnothérapeute</p>
    </div>
  </section>
</BaseLayout>
