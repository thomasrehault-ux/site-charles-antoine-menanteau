---
import BaseLayout from "../layouts/BaseLayout.astro";

const motifs = [
  {
    title: "Anxiété et stress",
    terms: [
      "crises d’angoisse",
      "tension intérieure",
      "sentiment de débordement",
      "inquiétude persistante",
      "insomnie",
      "ruminations",
      "anticipations anxieuses",
      "irritabilité",
      "agitation intérieure",
      "difficulté à s’apaiser"
    ]
  },
  {
    title: "Burn-out et dépression",
    terms: [
      "épuisement psychique",
      "perte d’élan",
      "retrait",
      "perte de repères",
      "fatigue morale",
      "anhédonie",
      "dévalorisation",
      "ralentissement",
      "ruminations",
      "difficulté à retrouver une énergie vitale"
    ]
  },
  {
    title: "Addictions",
    terms: [
      "dépendances",
      "répétitions",
      "conduites d’échappement",
      "rapport difficile à la limite",
      "rapport difficile au manque",
      "obsessions",
      "compulsions",
      "perte de contrôle",
      "recherche d’apaisement",
      "conduites à risque"
    ]
  },
  {
    title: "Troubles des conduites alimentaires (TCA)",
    terms: [
      "rapport conflictuel au corps",
      "rapport conflictuel à l’alimentation",
      "contrôle",
      "restriction",
      "crises",
      "hyperphagie",
      "boulimie",
      "anorexie",
      "image corporelle",
      "régulation émotionnelle"
    ]
  },
  {
    title: "Trauma",
    terms: [
      "événements difficiles",
      "traces persistantes",
      "empreintes traumatiques",
      "état d’alerte",
      "sidération",
      "envahissement émotionnel",
      "hypervigilance",
      "cauchemars à répétition",
      "dissociation",
      "évitements"
    ]
  },
  {
    title: "Deuil et perte de sens",
    terms: [
      "séparations",
      "ruptures",
      "décès",
      "remaniements de vie",
      "crises existentielles",
      "étapes de vie",
      "grossesse",
      "post-partum",
      "mariage",
      "déménagement",
      "réorientation professionnelle",
      "retraite"
    ]
  }
];
---

<BaseLayout
  title="Motifs de consultation | Charles-Antoine Menanteau"
  description="Motifs de consultation: anxiété, burn-out, addictions, troubles des conduites alimentaires, trauma, deuil et perte de sens."
  currentPath="/motifs"
>
  <section class="page-hero-grid">
    <div class="page-hero-copy">
      <p class="page-eyebrow">Motifs de consultation</p>
      <h1>Des difficultés différentes, une même attention à ce qui se vit.</h1>
      <span class="heading-rule"></span>
      <p class="page-intro">
        La consultation peut concerner des moments de souffrance psychique, de crise, d’épuisement
        ou de questionnement existentiel. Chaque situation est accueillie dans sa singularité.
      </p>
    </div>
    <div class="page-hero-visual">
      <div class="page-hero-art page-hero-art-motifs"></div>
    </div>
  </section>

  <section class="dynamic-grid page-section">
    {
      motifs.map((motif) => (
        <details class="content-card dynamic-panel">
          <summary class="dynamic-summary">
            <span class="dynamic-heading">{motif.title}</span>
            <span class="dynamic-toggle" aria-hidden="true"></span>
          </summary>
          <ul class="keyword-list" aria-label={`Mots-clés associés à ${motif.title}`}>
            {motif.terms.map((term) => <li>{term}</li>)}
          </ul>
        </details>
      ))
    }
  </section>
</BaseLayout>
