---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Parcours et formation | Charles-Antoine Menanteau"
  description="Parcours, formation, experience clinique et reperes de supervision de Charles-Antoine Menanteau."
  currentPath="/parcours"
>
  <section class="page-hero-grid">
    <div class="page-hero-copy">
      <p class="page-eyebrow">Parcours</p>
      <h1>Une pratique soutenue par la formation, l'experience clinique et la supervision.</h1>
      <span class="heading-rule"></span>
      <p class="page-intro">
        Cette page a vocation a presenter de facon plus detaillee le parcours universitaire, les
        formations complementaires, les transmissions recues et les champs d'experience clinique.
      </p>
    </div>
    <div class="page-hero-visual page-hero-visual-soft">
      <div class="page-hero-art page-hero-art-hero"></div>
    </div>
  </section>

  <section class="timeline page-section">
    <details class="timeline-item dynamic-panel" open>
      <summary class="dynamic-summary">
        <span>
          <span class="dynamic-kicker">Repère 01</span>
          <span class="dynamic-heading">Formation universitaire</span>
        </span>
        <span class="dynamic-toggle" aria-hidden="true"></span>
      </summary>
      <p>Master 2 de psychologie clinique, travaux de recherche et experience de terrain en clinique institutionnelle.</p>
    </details>
    <details class="timeline-item dynamic-panel">
      <summary class="dynamic-summary">
        <span>
          <span class="dynamic-kicker">Repère 02</span>
          <span class="dynamic-heading">Formations complementaires</span>
        </span>
        <span class="dynamic-toggle" aria-hidden="true"></span>
      </summary>
      <p>Hypnose therapeutique, rTMS, travail psycho-corporel, respiration, imaginaire et transmission phenomeno-existentielle.</p>
    </details>
    <details class="timeline-item dynamic-panel">
      <summary class="dynamic-summary">
        <span>
          <span class="dynamic-kicker">Repère 03</span>
          <span class="dynamic-heading">Experience clinique</span>
        </span>
        <span class="dynamic-toggle" aria-hidden="true"></span>
      </summary>
      <p>Consultations aupres d'adolescents et d'adultes, accompagnement des troubles alimentaires, des crises de sens, du trauma et de la depression.</p>
    </details>
  </section>
</BaseLayout>
